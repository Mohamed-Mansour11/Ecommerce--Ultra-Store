export enum OrderStatus {
  placed = 'placed',
  shipped = 'shipped',
  onWay = 'onWay',
  delivered = 'delivered',
  canceled = 'canceled',
  refunded = 'refunded',
}

export enum PaymentMethod {
  card = 'card',
  cash = 'cash', // COD cash on delivery
}

// Sub-Schema for Products
@Schema({ _id: false }) // ЩҶЩ…ЩҶШ№ Mongoose Щ…ЩҶ ШҘЩҶШҙШ§ШЎ ID ЩҒШұШ№ЩҠ Щ„ЩғЩ„ Щ…ЩҶШӘШ¬ ШҜШ§Ш®Щ„ Ш§Щ„ШЈЩҲШұШҜШұ
