// Ш§ШіШӘЩҠШұШ§ШҜ Щ…ЩҲШҜЩҠЩ„ Ш§Щ„Щ…ШіШӘШ®ШҜЩ… Щ„ШұШЁШ· Ш§Щ„ЩғЩҲШЁЩҲЩҶ ШЁШ§Щ„Щ…ШҜЩҠШұ Ш§Щ„Ш°ЩҠ ЩӮШ§Щ… ШЁШҘЩҶШҙШ§ШҰЩҮ (ЩҶЩҒШі Ш·ШұЩҠЩӮШӘЩғ ЩҒЩҠ Ш§Щ„Щ…ЩҶШӘШ¬)
import { UserModelName } from './user.model';

@Schema({ timestamps: true })
export class Coupon {
  @Prop({
    type: String,
    required: true,
    unique: true,
    index: { name: 'Coupon_code_index' }, // ШӘШіШұЩҠШ№ Ш§Щ„ШЁШӯШ« Ш№ЩҶ Ш§Щ„ЩғЩҲШЁЩҲЩҶ ЩҒЩҠ Ш§Щ„ШҜШ§ШӘШ§ ШЁЩҠШІ
    set: function (this: any, value: string) {
      // ШЁШҜЩ„ЩӢШ§ Щ…ЩҶ ШӘШӯЩҲЩҠЩ„ Ш§Щ„ШӯШұЩҲЩҒ Щ„ЩҖ Capital ЩҠШҜЩҲЩҠШ§ЩӢ ЩҒЩҠ Ш§Щ„ЩҖ ServiceШҢ
      // ЩҮШ°ЩҮ Ш§Щ„ШҜШ§Щ„Ш© ШіШӘЩӮЩҲЩ… ШЁШӘШӯЩҲЩҠЩ„ ШЈЩҠ ЩғЩҲШҜ ШҘЩ„Щү ШӯШұЩҲЩҒ ЩғШЁЩҠШұШ© ШӘЩ„ЩӮШ§ШҰЩҠШ§ЩӢ ЩӮШЁЩ„ Ш§Щ„ШӯЩҒШё
      return value.toUpperCase();
    },
  })
  code!: string;

  @Prop({ type: Types.ObjectId, ref: UserModelName, required: true })
  createdBy!: Types.ObjectId; // Щ„ШӘШіШ¬ЩҠЩ„ Щ…ЩҶ ЩҮЩҲ Ш§Щ„ШЈШҜЩ…ЩҶ Ш§Щ„Ш°ЩҠ ШЈЩҶШҙШЈ ЩҮШ°Ш§ Ш§Щ„ЩғЩҲШЁЩҲЩҶ

  @Prop({ type: Number, required: true, min: 0 })
  discount!: number; // ЩӮЩҠЩ…Ш© Ш§Щ„Ш®ШөЩ… (ШіЩҲШ§ШЎ ЩҶШіШЁШ© ШЈЩҲ Щ…ШЁЩ„Шә)

  @Prop({ type: String, required: true, enum: ['percentage', 'fixed'] })
  discountType!: string; // ЩҶЩҲШ№ Ш§Щ„Ш®ШөЩ…: ЩҶШіШЁШ© Щ…ШҰЩҲЩҠШ© ШЈЩҲ Щ…ШЁЩ„Шә Ш«Ш§ШЁШӘ

  @Prop({ type: Date, required: true })
  expirationDate!: Date; // ШӘШ§ШұЩҠШ® Ш§ЩҶШӘЩҮШ§ШЎ Ш§Щ„ЩғЩҲШЁЩҲЩҶ

  @Prop({ type: Boolean, default: true })
  isActive!: boolean; // Щ„Щ„ШӘШӯЩғЩ… ЩҒЩҠ ШҘЩҠЩӮШ§ЩҒ ЩҲШӘШҙШәЩҠЩ„ Ш§Щ„ЩғЩҲШЁЩҲЩҶ ШЁШ¶ШәШ·Ш© ШІШұ

  @Prop({ type: Number, default: null })
  usageLimit!: number; // Ш§Щ„ШӯШҜ Ш§Щ„ШЈЩӮШөЩү Щ„Щ„Ш§ШіШӘШ®ШҜШ§Щ… (null ШӘШ№ЩҶЩҠ Щ…ЩҒШӘЩҲШӯ)

  @Prop({ type: Number, default: 0 })
  usedCount!: number; // Ш№ШҜШ§ШҜ Ш§Щ„Ш§ШіШӘШ®ШҜШ§Щ… Ш§Щ„ЩҒШ№Щ„ЩҠ
}

// --- ШҘЩҶШҙШ§ШЎ Ш§Щ„ЩҖ Schema ЩҲШ§Щ„ЩҖ Model ---

export const CouponSchema = SchemaFactory.createForClass(Coupon);

export const CouponModelName = Coupon.name;

// ШӘШөШҜЩҠШұ Ш§Щ„Щ…ЩҲШҜЩҠЩҲЩ„ Ш¬Ш§ЩҮШІШ§ЩӢ Щ„ЩҠШӘЩ… Ш§ШіШӘЩҠШұШ§ШҜЩҮ Щ…ШЁШ§ШҙШұШ© ЩҒЩҠ Ш§Щ„ЩҖ app.module ШЈЩҲ Ш§Щ„ЩҖ order.module
export const CouponModel = MongooseModule.forFeature([
  { name: CouponModelName, schema: CouponSchema },
]);

// ШӘШ№ШұЩҠЩҒ Ш§Щ„ЩҖ Document Ш§Щ„Ш®Ш§Шө ШЁШ§Щ„ЩғЩҲШЁЩҲЩҶ Щ„ЩҠШіШ§Ш№ШҜ TypeScript ЩҒЩҠ Ш§Щ„ШҘЩғЩ…Ш§Щ„ Ш§Щ„ШӘЩ„ЩӮШ§ШҰЩҠ
export type CouponDocument = HydratedDocument<Coupon>;

