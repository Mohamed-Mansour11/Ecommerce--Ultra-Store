} from 'cloudinary';
import { Image } from 'src/common/types/image.type';

@Injectable()
export class FileUploadService {
  constructor(@Inject(CLOUDINARY) private cloudinary: typeof Cloudinary) {}

  // ШҜШ§Щ„Ш© Щ„ШұЩҒШ№ Щ…Щ„ЩҒ ЩҲШ§ШӯШҜ ШҘЩ„Щү Cloudinary ШЁШ§ШіШӘШ®ШҜШ§Щ… Ш§Щ„ЩҖ Stream
  async uploadCloud(
    buffer: Buffer,
    options: UploadApiOptions,
  ): Promise<UploadApiResponse> {
    return new Promise((resolve, reject) => {
      this.cloudinary.uploader
        .upload_stream(options, (error, result) => {
          if (error) return reject(error);
          return resolve(result!);
        })
        .end(buffer);
    });
  }

  // ШҜШ§Щ„Ш© Щ„Щ…Ш№Ш§Щ„Ш¬Ш© ЩҲШұЩҒШ№ Щ…ШөЩҒЩҲЩҒШ© Щ…ЩҶ Ш§Щ„Щ…Щ„ЩҒШ§ШӘ
  async saveFileToCloud(
    files: Express.Multer.File[],
    options: UploadApiOptions,
  ) {
    let savedFiles: Image[] = [];

    for (const file of files) {
      let buffer = file.buffer;
      const { secure_url, public_id } = await this.uploadCloud(buffer, options);
      savedFiles.push({ secure_url, public_id });
    }

    return savedFiles;
  }

  // ШӯШ°ЩҒ Щ…Ш¬Щ…ЩҲШ№Ш© Щ…ЩҶ Ш§Щ„Щ…Щ„ЩҒШ§ШӘ ШЁШ§ШіШӘШ®ШҜШ§Щ… publicIds
  async deleteFiles(publicIds: string[]) {
    await this.cloudinary.api.delete_resources(publicIds);
  }

  // ШӯШ°ЩҒ Щ…Ш¬Щ„ШҜ ШЁШ§Щ„ЩғШ§Щ…Щ„ (ШЁЩ…Ш§ ЩҠШӯШӘЩҲЩҠЩҮ Щ…ЩҶ Щ…Щ„ЩҒШ§ШӘ ЩҲЩ…Ш¬Щ„ШҜШ§ШӘ ЩҒШұШ№ЩҠШ©)
  async deleteFolder(folderPath: string) {
    // 1. ШӯШ°ЩҒ Ш¬Щ…ЩҠШ№ Ш§Щ„Щ…Щ„ЩҒШ§ШӘ Ш§Щ„Щ…ЩҲШ¬ЩҲШҜШ© ШҜШ§Ш®Щ„ Ш§Щ„Щ…Ш¬Щ„ШҜ ШЈЩҲЩ„Ш§ЩӢ
    await this.cloudinary.api.delete_resources_by_prefix(folderPath);

    // 2. Ш¬Щ„ШЁ ЩӮШ§ШҰЩ…Ш© ШЁШ§Щ„Щ…Ш¬Щ„ШҜШ§ШӘ Ш§Щ„ЩҒШұШ№ЩҠШ© (Sub-folders)
    const subFolders = await this.cloudinary.api.sub_folders(folderPath);

    // 3. ШҘШ°Ш§ ЩҲШ¬ШҜШӘ Щ…Ш¬Щ„ШҜШ§ШӘ ЩҒШұШ№ЩҠШ©ШҢ ЩӮЩ… ШЁШӯШ°ЩҒЩҮШ§ ШЁШҙЩғЩ„ ШӘЩғШұШ§ШұЩҠ (Recursive)
    if (subFolders.folders.length) {
      for (const subfolder of subFolders.folders) {
        await this.deleteFolder(subfolder.path);
      }
    }

    // 4. ШЁШ№ШҜ Ш§Щ„ШӘШЈЩғШҜ Щ…ЩҶ ШЈЩҶ Ш§Щ„Щ…Ш¬Щ„ШҜ ШЈШөШЁШӯ ЩҒШ§ШұШәШ§ЩӢ ШӘЩ…Ш§Щ…Ш§ЩӢШҢ ЩӮЩ… ШЁШӯШ°ЩҒЩҮ
    await this.cloudinary.api.delete_folder(folderPath);
  }
}

```

