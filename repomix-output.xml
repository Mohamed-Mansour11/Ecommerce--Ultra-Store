import { Injectable, NotFoundException } from '@nestjs/common';
import { FileUploadService } from 'src/common/services/fileupload/fileupload.service';
import { ConfigService } from '@nestjs/config';
import { CreateCategoryDto } from './dto/create-category.dto';
import { Types } from 'mongoose';
import { CategoryRepository } from 'src/DB/repositories/category.repository';
import { nanoid } from 'nanoid';
import { UpdateCategoryDto } from './dto/update-category.dto';

@Injectable()
export class CategoryService {
  constructor(
    private readonly _FileUploadService: FileUploadService,
    private readonly _configService: ConfigService,
    private readonly _CategoryRepository: CategoryRepository,
  ) {}
  //Ш§Щ„Ш®ШҜЩ…Ш§ШӘ ЩҲШ§Щ„ШЈШҜЩҲШ§ШӘ ШЈЩҲ Ш§Щ„Щ…Ш№ШҜШ§ШӘ Ш§Щ„ШӘЩҠ ШіЩҶШіШӘШ®Щ…ЩҮШ§ constructor ЩҶШ¶Ш№ ЩҒЩҠ Ш§Щ„ЩҖ

  async create(
    data: CreateCategoryDto,
    userId: Types.ObjectId,
    file: Express.Multer.File,
    // ЩҒЩҮЩҠ Ш§Щ„Щ…ЩҲШ§ШҜ Ш§Щ„Ш®Ш§Щ… Ш§Щ„ШӘЩҠ ЩҶШіШӘШ®ШҜЩ…ЩҮШ§ ЩҲШ§Щ„ШӘЩҠ ШӘШ®ШӘЩ„ЩҒ ШЁШ§Ш®ШӘЩ„Ш§ЩҒ Ш§Щ„Щ…Ш·Щ„ЩҲШЁ ЩҲЩ„ЩҠЩҖЩҖШіШӘ ЩҮЩҠ Ш§Щ„Щ…Ш№ШҜШ§ШӘ
  ) {
    // Ш¬Щ„ШЁ Ш§Щ„Щ…ШіШ§Шұ Ш§Щ„ШұШҰЩҠШіЩҠ Щ…ЩҶ ШҘШ№ШҜШ§ШҜШ§ШӘ Ш§Щ„ЩҶШёШ§Щ…
    const rootfolder = this._configService.get('CLOUD_ROOT_FOLDER');

    //  ШҘЩҶШҙШ§ШЎ Щ…Ш№ШұЩҒ ЩҒШұЩҠШҜ Щ„Щ„Щ…Ш¬Щ„ШҜ Ш§Щ„Ш¬ШҜЩҠШҜ(ЩҠЩ…ЩғЩҶЩғ Ш§ШіШӘШ®ШҜШ§Щ… nanoid ЩғЩ…Ш§ ШёЩҮШұ ЩҒЩҠ Terminal)
    const cloudFolder = nanoid();

    // ШұЩҒШ№ Ш§Щ„ШөЩҲШұШ© ШҘЩ„Щү Cloudinary ЩҒЩҠ Щ…Ш¬Щ„ШҜ Щ…Ш®ШөШө
    const results = await this._FileUploadService.saveFileToCloud([file], {
      folder: `${rootfolder}/category/${cloudFolder}`,
    });

    // ШӯЩҒШё ШЁЩҠШ§ЩҶШ§ШӘ Ш§Щ„ЩҒШҰШ© ЩҒЩҠ ЩӮШ§Ш№ШҜШ© Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ
    const category = await this._CategoryRepository.create({
      name: data.name,
      cloudFolder,
      image: results[0],
      createdBy: userId,
    });

    return { data: category };
  }

  async update(
    categoryId: Types.ObjectId,
    updateCategoryDto: UpdateCategoryDto,
    userId: Types.ObjectId,
  ) {
    // 1. Ш§Щ„ШЁШӯШ« Ш№ЩҶ Ш§Щ„ЩҒШҰШ© (Category) ШЁШ§ШіШӘШ®ШҜШ§Щ… Ш§Щ„ЩҖ Repository
    const category = await this._CategoryRepository.findOne({
      filter: { _id: categoryId },
    });

    //  Ш§Щ„ШӘШӯЩӮЩӮ Щ…ЩҶ ЩҲШ¬ЩҲШҜ Ш§Щ„ЩҒШҰШ©ШҢ ЩҲШҘШ°Ш§ Щ„Щ… ШӘЩҲШ¬ШҜ ЩҠШӘЩ… ШұЩ…ЩҠ Ш®Ш·ШЈ
    if (!category) {
      throw new NotFoundException(`category with id ${categoryId} not found!`);
    }

    //  DTO ШӘШӯШҜЩҠШ« Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ ШҘШ°Ш§ ЩғШ§ЩҶШӘ Щ…ЩҲШ¬ЩҲШҜШ© ЩҒЩҠ Ш§Щ„ЩҖ
    // image > (ШӘЩ…ШӘ Щ…Ш№Ш§Щ„Ш¬ШӘЩҮ ЩҒЩҠ ШҜШ§Щ„Ш© ШЈШ®ШұЩү)
    if (updateCategoryDto.name) {
      category.name = updateCategoryDto.name;
      category.updatedBy = userId; // ШӘШ№ЩҠЩҠЩҶ Ш§Щ„Щ…ШіШӘШ®ШҜЩ… Ш§Щ„Ш°ЩҠ ЩӮШ§Щ… ШЁШ§Щ„ШӘШӯШҜЩҠШ«
      await category.save(); // ШӯЩҒШё Ш§Щ„ШӘШәЩҠЩҠШұШ§ШӘ ЩҒЩҠ ЩӮШ§Ш№ШҜШ© Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ
    }

    // 4. ШҘШұШ¬Ш§Ш№ Ш§Щ„ЩҶШӘЩҠШ¬Ш© Ш§Щ„ЩҶЩҮШ§ШҰЩҠШ©
    return { data: category };
  }

  // ШіЩҠШҜШ®Щ„ Ш§Щ„ЩҶШёШ§Щ… ШҘЩ„Щү ШҜШ§Ш®Щ„ Ш§Щ„ЩҖ if ЩҲЩҠЩҶЩҒШ° Ш§Щ„ШіШ·Шұ: category.name = updateCategoryDto.name;
  // ШЁЩ…Ш§ ШЈЩҶ Ш§Щ„ЩғШ§ШҰЩҶ ЩҒШ§ШұШәШҢ ЩҒШҘЩҶ updateCategoryDto.name ШәЩҠШұ Щ…ЩҲШ¬ЩҲШҜШ©ШҢ ЩҲЩӮЩҠЩ…ШӘЩҮШ§ ШЁШұЩ…Ш¬ЩҠШ§ЩӢ ЩҮЩҠ undefined.
  // Ш§Щ„ЩғШ§ШұШ«Ш©: ШЈЩҶШӘ Ш§Щ„ШўЩҶ ЩӮЩ…ШӘ ШЁЩ…ШіШӯ Ш§ШіЩ… Ш§Щ„ЩӮШіЩ… Ш§Щ„ЩӮШҜЩҠЩ… Щ…ЩҶ ЩӮШ§Ш№ШҜШ© Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ ЩҲШ§ШіШӘШЁШҜЩ„ШӘЩҮ ШЁЩҖ undefined.
  // ЩҲШҘШ°Ш§ ЩғШ§ЩҶ ШӯЩӮЩ„ Ш§Щ„Ш§ШіЩ… ШҘШ¬ШЁШ§ШұЩҠШ§ЩӢ (Required) ЩҒЩҠ ЩҶЩ…ЩҲШ°Ш¬ Mongoose Ш§Щ„Ш®Ш§Шө ШЁЩғШҢ ЩҒШіЩҲЩҒ ЩҠЩҶЩҮШ§Шұ Ш§Щ„Ш·Щ„ШЁ ЩҲЩҠЩҸШұШ¬Ш№ Ш®Ш·ШЈ

  async updateImage(
    categoryId: Types.ObjectId,
    file: Express.Multer.File,
    userId: Types.ObjectId,
  ) {
    // 1. Ш§Щ„ШӘШЈЩғШҜ Щ…ЩҶ ЩҲШ¬ЩҲШҜ Ш§Щ„ЩҒШҰШ© ЩҒЩҠ ЩӮШ§Ш№ШҜШ© Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ
    const category = await this._CategoryRepository.findOne({
      filter: { _id: categoryId },
    });

    if (!category) {
      throw new NotFoundException(`category with id ${categoryId} not found!`);
    }

    // 2. ШӘШӯШҜЩҠШ« Ш§Щ„ШөЩҲШұШ© Ш№Щ„Щү Cloudinary
    // ЩҶШұШіЩ„ Ш§Щ„ЩҖ public_id Ш§Щ„ЩӮШҜЩҠЩ… Щ„ЩғЩҠ ЩҠЩӮЩҲЩ… Cloudinary ШЁШ§ШіШӘШЁШҜШ§Щ„ Ш§Щ„ШөЩҲШұШ© Ш§Щ„ЩӮШҜЩҠЩ…Ш© ШЁЩҶЩҒШі Ш§Щ„Щ…Ш№ШұЩҒ
    //:Ш§Щ„ШҘЩ…ШіШ§Щғ ШЁШ№ЩҶЩҲШ§ЩҶ Ш§Щ„ШөЩҲШұШ© Ш§Щ„ЩӮШҜЩҠЩҖЩҖЩҖЩҖЩҖЩҖЩҖЩҖЩ…ЩҖЩҖЩҖЩҖЩҖЩҖШ©

    const public_id = category.image.public_id;
    // Ш№Щ…Щ„ЩҠШ© Ш§Щ„ШұЩҒШ№ ЩҲШ§Щ„Ш§ШіШӘШЁШҜШ§Щ„ Ш§Щ„Ш°ЩғЩҠШ©
    const results = await this._FileUploadService.saveFileToCloud([file], {
      public_id,
    });
    //public_id ШЁШҜЩҲЩҶ ШӘЩ…ШұЩҠШұ Ш§Щ„ file= Щ„ЩҲ ШұЩҒШ№ЩҶШ§ Ш§Щ„ШөЩҲШұШ© Ш§Щ„Ш¬ШҜЩҠШҜШ©
    //ШЁШұЩҒШ№ЩҮШ§ ЩғЩ…Щ„ЩҒ Ш¬ШҜЩҠШҜ ЩғЩ„ЩҠШ§ЩӢ ШЁЩ…Ш№ШұЩҒ Ш¬ШҜЩҠШҜ ЩҲШұШ§ШЁШ· Ш¬ШҜЩҠШҜ Cloudinary ШіЩҠЩӮЩҲЩ…

    // 3. ШӘШӯШҜЩҠШ« ШЁЩҠШ§ЩҶШ§ШӘ Ш§Щ„ЩҒШҰШ© ЩҒЩҠ ЩӮШ§Ш№ШҜШ© Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ
    category.image = results[0];
    category.updatedBy = userId;
    await category.save();

    return { data: category };
  }

  async remove(categoryId: Types.ObjectId, userId: Types.ObjectId) {
    // 1. Ш§Щ„ШЁШӯШ« Ш№ЩҶ Ш§Щ„ЩҒШҰШ© Щ„Щ„ШӘШЈЩғШҜ Щ…ЩҶ ЩҲШ¬ЩҲШҜЩҮШ§
    const category = await this._CategoryRepository.findOne({
      filter: { _id: categoryId },
    });

    // 2. ШұЩ…ЩҠ Ш®Ш·ШЈ ШҘШ°Ш§ Щ„Щ… ЩҠШӘЩ… Ш§Щ„Ш№Ш«ЩҲШұ Ш№Щ„ЩҠЩҮШ§
    if (!category) {
      throw new NotFoundException(`category with id ${categoryId} not found!`);
    }

    // 3. ШӯШ°ЩҒ Ш§Щ„ЩҒШҰШ© Щ…ЩҶ ЩӮШ§Ш№ШҜШ© Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ
    await category.deleteOne();

    // 4. ШҘШұШ¬Ш§Ш№ ШұШіШ§Щ„Ш© ЩҶШ¬Ш§Шӯ
    return { message: 'done' };
  }

  async findOne(categoryId: Types.ObjectId) {
    // Ш§Щ„ШЁШӯШ« Ш№ЩҶ Ш§Щ„ЩҒШҰШ© ШЁШ§ШіШӘШ®ШҜШ§Щ… Ш§Щ„ЩҖ Repository
    const category = await this._CategoryRepository.findOne({
      filter: { _id: categoryId },
    });

    // ШҘШ°Ш§ Щ„Щ… ЩҠШӘЩ… Ш§Щ„Ш№Ш«ЩҲШұ Ш№Щ„Щү Ш§Щ„ЩҒШҰШ©ШҢ ЩҠШӘЩ… ШұЩ…ЩҠ Ш®Ш·ШЈ 404
    if (!category) {
      throw new NotFoundException(`category with id ${categoryId} not found!`);
    }

    // ШҘШұШ¬Ш§Ш№ Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ ЩҒЩҠ ШӯШ§Щ„ ЩҲШ¬ЩҲШҜЩҮШ§
    return { data: category };
  }

  async findAll(page: number) {
    return {
      data: await this._CategoryRepository.findAll({
        populate: [{ path: 'createdBy' }],
        paginate: { page },
      }),
    };
  }
}
