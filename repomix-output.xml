export class Coupon {
  @Prop({
    type: String,
    required: true,
    unique: true,
    index: { name: 'Coupon_code_index' }, // ШӘШіШұЩҠШ№ Ш§Щ„ШЁШӯШ« Ш№ЩҶ Ш§Щ„ЩғЩҲШЁЩҲЩҶ ЩҒЩҠ Ш§Щ„ШҜШ§ШӘШ§ ШЁЩҠШІ
    set: function (this: any, value: string) {
      // ШЁШҜЩ„ЩӢШ§ Щ…ЩҶ ШӘШӯЩҲЩҠЩ„ Ш§Щ„ШӯШұЩҲЩҒ Щ„ЩҖ Capital ЩҠШҜЩҲЩҠШ§ЩӢ ЩҒЩҠ Ш§Щ„ЩҖ ServiceШҢ
