import { BadRequestException, Injectable } from '@nestjs/common';
import { CreateReviewDto } from './dto/create-review.dto';
import { Types } from 'mongoose';
import { ReviewRepository } from 'src/DB/repositories/review.repository';
import { OrderRepository } from 'src/DB/repositories/order.repository';
import { ProductService } from '../product/product.service';
import { OrderStatus } from 'src/DB/models/order.model';

@Injectable()
export class ReviewService {
  constructor(
    private readonly _ReviewRepository: ReviewRepository,
    private readonly _OrderRepository: OrderRepository,
    private readonly _ProductService: ProductService,
  ) {}

  async addReview(data: CreateReviewDto, userId: Types.ObjectId) {
    // 1. Ш§Щ„ШӘШЈЩғШҜ ШЈЩҶ Ш§Щ„Щ…ЩҶШӘШ¬ Щ…ЩҲШ¬ЩҲШҜ
    const product = await this._ProductService.checkProductExistence(
      data.productId as any,
    );

    // 2. ЩҒШӯШө ЩҮЩ„ ЩӮШ§Щ… Ш§Щ„Ш№Щ…ЩҠЩ„ ШЁШҙШұШ§ШЎ ЩҮШ°Ш§ Ш§Щ„Щ…ЩҶШӘШ¬ ЩҲЩҮЩ„ Ш§ШіШӘЩ„Щ…ЩҮШҹ
    // ШӘШЈЩғШҜ ШЈЩҶ OrderRepository ЩҠШіШӘШ®ШҜЩ… ЩҶЩҒШі Ш§Щ„ЩҖ Abstract Repository Щ„ЩҠЩӮШЁЩ„ Ш§Щ„ЩҖ filter
    const hasBoughtAndReceived = await this._OrderRepository.findOne({
      filter: {
        user: userId,
        orderStatus: OrderStatus.delivered,
        'products.productId': data.productId,
      },
    });

    if (!hasBoughtAndReceived) {
      throw new BadRequestException(
        'Щ„Ш§ ЩҠЩ…ЩғЩҶЩғ ШӘЩӮЩҠЩҠЩ… ЩҮШ°Ш§ Ш§Щ„Щ…ЩҶШӘШ¬. ЩҠШ¬ШЁ ШЈЩҶ ШӘЩғЩҲЩҶ ЩӮШҜ Ш§ШҙШӘШұЩҠШӘЩҮ ЩҲШ§ШіШӘЩ„Щ…ШӘЩҮ ШЈЩҲЩ„Ш§ЩӢ.',
      );
    }

    // 3. ЩҒШӯШө ЩҮЩ„ ЩӮШ§Щ… ШЁШӘЩӮЩҠЩҠЩ…ЩҮ Щ…ЩҶ ЩӮШЁЩ„Шҹ
    // рҹ’Ў Щ„Ш§ШӯШё ЩҮЩҶШ§: Ш§ШіШӘШ®ШҜЩ…ЩҶШ§ { filter: { ... } } ШЁЩҶШ§ШЎЩӢ Ш№Щ„Щү AbstractRepository
    const existingReview = await this._ReviewRepository.findOne({
      filter: {
        user: userId,
        product: data.productId,
      },
    });

    if (existingReview) {
      throw new BadRequestException('Щ„ЩӮШҜ ЩӮЩ…ШӘ ШЁШӘЩӮЩҠЩҠЩ… ЩҮШ°Ш§ Ш§Щ„Щ…ЩҶШӘШ¬ Щ…ШіШЁЩӮШ§ЩӢ.');
    }

    // 4. ШҘЩҶШҙШ§ШЎ Ш§Щ„ШӘЩӮЩҠЩҠЩ… ЩҲШӯЩҒШёЩҮ
    const review = await this._ReviewRepository.create({
      user: userId,
      product: new Types.ObjectId(data.productId as string) as any,
      rating: data.rating,
      comment: data.comment,
    });

    // ШӘШӯШҜЩҠШ« (Average Rating) ЩҒЩҠ Ш¬ШҜЩҲЩ„ Ш§Щ„Щ…ЩҶШӘШ¬Ш§ШӘ
    await this.updateProductAverageRating(data.productId);

    return { message: 'ШӘЩ… ШҘШ¶Ш§ЩҒШ© Ш§Щ„ШӘЩӮЩҠЩҠЩ… ШЁЩҶШ¬Ш§Шӯ', review };
  }

  // Ш¬Щ„ШЁ ШӘЩӮЩҠЩҠЩ…Ш§ШӘ Щ…ЩҶШӘШ¬ Щ…Ш№ЩҠЩҶ Щ…Ш№ ШҜШ№Щ… Ш§Щ„ЩҖ Populate Щ„Щ…Ш№ШұЩҒШ© Ш§ШіЩ… ШөШ§ШӯШЁ Ш§Щ„ШӘЩӮЩҠЩҠЩ…
  async getProductReviews(productId: string) {
    // рҹ’Ў Щ„Ш§ШӯШё ЩҮЩҶШ§: Ш§ШіШӘШ®ШҜЩ…ЩҶШ§ findAll ЩҲЩ…ШұШұЩҶШ§ filter ЩҲ populate
    const result = await this._ReviewRepository.findAll({
      filter: { product: productId },
      populate: { path: 'user', select: 'name image' }, // Щ„Ш¬Щ„ШЁ ШөЩҲШұШ© ЩҲШ§ШіЩ… Ш§Щ„Ш№Щ…ЩҠЩ„
    });

    // Ш§Щ„ШҜШ§Щ„Ш© findAll Щ„ШҜЩҠЩғ ШӘШұШ¬Ш№ ЩғШ§ШҰЩҶ ЩҠШӯШӘЩҲЩҠ Ш№Щ„Щү (totalSize, data, Ш§Щ„Ш®..)
    return {
      count: result.totalSize,
      reviews: result.data,
    };
  }

  // ==========================================
  // ШҜШ§Щ„Ш© Щ…ШіШ§Ш№ШҜШ© Щ„ШӘШӯШҜЩҠШ« Щ…ШӘЩҲШіШ· Ш§Щ„ШӘЩӮЩҠЩҠЩ…Ш§ШӘ ЩҒЩҠ Ш§Щ„Щ…ЩҶШӘШ¬
  // ==========================================
  private async updateProductAverageRating(productId: string) {
    const result = await this._ReviewRepository.findAll({
      filter: { product: productId },
      // Щ„ЩҶ ЩҶШӯШӘШ§Ш¬ Щ„ЩҖ Pagination ЩҮЩҶШ§ Щ„ШЈЩҶЩҶШ§ ЩҶШұЩҠШҜ ШӯШіШ§ШЁ ЩғЩ„ Ш§Щ„ШӘЩӮЩҠЩҠЩ…Ш§ШӘ
      // ЩҠЩ…ЩғЩҶЩғ ШӘЩ…ШұЩҠШұ limit ЩғШЁЩҠШұ ШЈЩҲ ШӘШ№ШҜЩҠЩ„ findAll Щ„ШӘШӘШ¬Ш§ЩҮЩ„ Ш§Щ„ЩҖ limit Щ„ЩҲ Щ„Щ… ЩҠЩҸЩ…ШұШұ paginate
    });

    const reviews = result.data || [];

    if (reviews.length > 0) {
      const sum = reviews.reduce((acc, item) => acc + item.rating, 0);
      const avgRating = sum / reviews.length;

      // Ш§Щ„ШҜШ§Щ„Ш© ШҜЩҠ Ш§Щ„Щ…ЩҒШұЩҲШ¶ ШӘЩғЩҲЩҶ Щ…ЩҲШ¬ЩҲШҜШ© ЩҒЩҠ Ш§Щ„ЩҖ ProductService
      await this._ProductService.updateProductRating(
        productId,
        avgRating,
        reviews.length,
      );
    }
  }
}
</file>

