import {
  IsString,
  IsNumber,
  IsEnum,
  IsDate,
  IsOptional,
  IsBoolean,
  Min,
  IsNotEmpty,
} from 'class-validator';
import { Type } from 'class-transformer';

export class CreateCouponDto {
  @IsString()
  @IsNotEmpty({ message: 'ЩғЩҲШҜ Ш§Щ„ЩғЩҲШЁЩҲЩҶ Щ…Ш·Щ„ЩҲШЁ' })
  code!: string;

  @IsNumber()
  @Min(0, { message: 'ЩӮЩҠЩ…Ш© Ш§Щ„Ш®ШөЩ… Щ„Ш§ ЩҠЩ…ЩғЩҶ ШЈЩҶ ШӘЩғЩҲЩҶ ШЁШ§Щ„ШіШ§Щ„ШЁ' })
  discount!: number;

  @IsEnum(['percentage', 'fixed'], {
    message: 'ЩҶЩҲШ№ Ш§Щ„Ш®ШөЩ… ЩҠШ¬ШЁ ШЈЩҶ ЩҠЩғЩҲЩҶ percentage ШЈЩҲ fixed',
  })
  discountType!: string;

  @IsDate()
  @Type(() => Date) // ШӘШӯЩҲЩҠЩ„ Ш§Щ„ЩҶШө Ш§Щ„ЩӮШ§ШҜЩ… Щ…ЩҶ Ш§Щ„ЩҖ Request ШҘЩ„Щү ЩғШ§ШҰЩҶ Date ШӯЩӮЩҠЩӮЩҠ
  @IsNotEmpty({ message: 'ШӘШ§ШұЩҠШ® Ш§Щ„Ш§ЩҶШӘЩҮШ§ШЎ Щ…Ш·Щ„ЩҲШЁ' })
  expirationDate!: Date;

  @IsOptional()
  @IsBoolean()
  isActive?: boolean;

  @IsOptional()
  @IsNumber()
  @Min(1, { message: 'ШӯШҜ Ш§Щ„Ш§ШіШӘШ®ШҜШ§Щ… ЩҠШ¬ШЁ ШЈЩҶ ЩҠЩғЩҲЩҶ 1 Ш№Щ„Щү Ш§Щ„ШЈЩӮЩ„' })
  usageLimit?: number;
}
