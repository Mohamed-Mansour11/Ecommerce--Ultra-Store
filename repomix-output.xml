  isActive!: boolean; // Щ„Щ„ШӘШӯЩғЩ… ЩҒЩҠ ШҘЩҠЩӮШ§ЩҒ ЩҲШӘШҙШәЩҠЩ„ Ш§Щ„ЩғЩҲШЁЩҲЩҶ ШЁШ¶ШәШ·Ш© ШІШұ

  @Prop({ type: Number, default: null })
  usageLimit!: number; // Ш§Щ„ШӯШҜ Ш§Щ„ШЈЩӮШөЩү Щ„Щ„Ш§ШіШӘШ®ШҜШ§Щ… (null ШӘШ№ЩҶЩҠ Щ…ЩҒШӘЩҲШӯ)

  @Prop({ type: Number, default: 0 })
  usedCount!: number; // Ш№ШҜШ§ШҜ Ш§Щ„Ш§ШіШӘШ®ШҜШ§Щ… Ш§Щ„ЩҒШ№Щ„ЩҠ
}

// --- ШҘЩҶШҙШ§ШЎ Ш§Щ„ЩҖ Schema ЩҲШ§Щ„ЩҖ Model ---

export const CouponSchema = SchemaFactory.createForClass(Coupon);

export const CouponModelName = Coupon.name;

// ШӘШөШҜЩҠШұ Ш§Щ„Щ…ЩҲШҜЩҠЩҲЩ„ Ш¬Ш§ЩҮШІШ§ЩӢ Щ„ЩҠШӘЩ… Ш§ШіШӘЩҠШұШ§ШҜЩҮ Щ…ШЁШ§ШҙШұШ© ЩҒЩҠ Ш§Щ„ЩҖ app.module ШЈЩҲ Ш§Щ„ЩҖ order.module
