import { Injectable } from '@nestjs/common';
import { InjectModel } from '@nestjs/mongoose';
import { Model } from 'mongoose';
import { Order, OrderDocument } from 'src/DB/models/order.model';
import { Coupon, CouponDocument } from 'src/DB/models/coupon.model';
import { User, UserDocument } from 'src/DB/models/user.model';

@Injectable()
export class AnalyticsService {
  constructor(
    @InjectModel(Order.name) private readonly orderModel: Model<OrderDocument>,
    @InjectModel(Coupon.name)
    private readonly couponModel: Model<CouponDocument>,
    @InjectModel(User.name) private readonly userModel: Model<UserDocument>,
  ) {}

  async getAdminDashboardStats() {
    // 1. ШҘШӯШөШ§ШҰЩҠШ§ШӘ Ш§Щ„ШЈШұШЁШ§Шӯ (ШҘШ¬Щ…Ш§Щ„ЩҠ Ш§Щ„Щ…ШЁЩҠШ№Ш§ШӘ Щ„Щ„Ш·Щ„ШЁШ§ШӘ Ш§Щ„Щ…ШҜЩҒЩҲШ№Ш© ЩҒЩӮШ·)
    // Щ…Щ„Ш§ШӯШёШ©: ШӘШЈЩғШҜ ШЈЩҶ Ш§ШіЩ… ШӯЩӮЩ„ Ш§Щ„ШіШ№Шұ Ш§Щ„ЩҶЩҮШ§ШҰЩҠ ЩҒЩҠ Ш§Щ„ШЈЩҲШұШҜШұ Щ„ШҜЩҠЩғ ЩҮЩҲ finalPrice ШЈЩҲ totalPrice
    const revenueStats = await this.orderModel.aggregate([
      { $match: { paid: true } }, // ЩҶШ¬Щ…Ш№ ШЈШұШЁШ§Шӯ Ш§Щ„Ш·Щ„ШЁШ§ШӘ Ш§Щ„ЩҶШ§Ш¬ШӯШ© ЩҒЩӮШ·
      {
        $group: {
          _id: null,
          totalRevenue: { $sum: '$finalPrice' }, // Щ…Ш¬Щ…ЩҲШ№ Ш§Щ„ШЈШұШЁШ§Шӯ
          totalOrders: { $sum: 1 }, // Ш№ШҜШҜ Ш§Щ„Ш·Щ„ШЁШ§ШӘ Ш§Щ„Щ…ШҜЩҒЩҲШ№Ш©
        },
      },
    ]);

    // 2. Ш§Щ„ЩғЩҲШЁЩҲЩҶШ§ШӘ Ш§Щ„ШЈЩғШ«Шұ Ш§ШіШӘШ®ШҜШ§Щ…Ш§ЩӢ (ШЈЩҒШ¶Щ„ 5 ЩғЩҲШЁЩҲЩҶШ§ШӘ)
    const topCoupons = await this.couponModel
      .find({ usedBy: { $exists: true, $not: { $size: 0 } } }) // ЩҶШ¬Щ„ШЁ Ш§Щ„ЩғЩҲШЁЩҲЩҶШ§ШӘ Ш§Щ„ШӘЩҠ ШӘЩ… Ш§ШіШӘШ®ШҜШ§Щ…ЩҮШ§
      // ШЈЩҲ ШҘШ°Ш§ ЩғШ§ЩҶ Щ„ШҜЩҠЩғ ШӯЩӮЩ„ Ш¬Ш§ЩҮШІ Щ„Щ„Ш№ШҜШ§ШҜ Щ…Ш«Щ„ usageCount Ш§ШіШӘШ®ШҜЩ…ЩҮ Щ„Щ„ШӘШұШӘЩҠШЁ:
      // .sort({ usageCount: -1 })
      .select('name code discount amount usedBy') // ЩҶШ¬Щ„ШЁ Ш§Щ„ШӯЩӮЩҲЩ„ Ш§Щ„Щ…ЩҮЩ…Ш© ЩҒЩӮШ·
      .limit(5)
      .lean();

    // 3. ШӘШӯЩ„ЩҠЩ„ ШӯШ§Щ„Ш§ШӘ Ш§Щ„Ш·Щ„ШЁШ§ШӘ (ЩғЩ… Ш·Щ„ШЁ ЩӮЩҠШҜ Ш§Щ„ШӘЩҶЩҒЩҠШ°ШҢ ЩғЩ… Ш·Щ„ШЁ ШӘЩ… ШӘЩҲШөЩҠЩ„ЩҮШҹ)
    const ordersBreakdown = await this.orderModel.aggregate([
      {
        $group: {
          _id: '$orderStatus', // ШӘШ¬Щ…ЩҠШ№ ШЁЩҶШ§ШЎЩӢ Ш№Щ„Щү ШӯШ§Щ„Ш© Ш§Щ„Ш·Щ„ШЁ
          count: { $sum: 1 },
        },
      },
    ]);

    // 4. ШҘШ¬Щ…Ш§Щ„ЩҠ Ш№ШҜШҜ Ш§Щ„Ш№Щ…Щ„Ш§ШЎ Ш§Щ„Щ…ШіШ¬Щ„ЩҠЩҶ
    const totalUsers = await this.userModel.countDocuments({ role: 'User' }); // Ш§ЩҒШӘШұШ¶ ШЈЩҶ Ш§Щ„ШұЩҲЩ„ Ш§ШіЩ…ЩҮШ§ User

    // ШӘШ¬Щ…ЩҠШ№ Ш§Щ„ШЁЩҠШ§ЩҶШ§ШӘ ЩҲШҘШұШіШ§Щ„ЩҮШ§ Щ„Щ„ЩҖ Frontend
    return {
      overview: {
        totalRevenue: revenueStats[0]?.totalRevenue || 0,
        totalPaidOrders: revenueStats[0]?.totalOrders || 0,
        totalUsers,
      },
      ordersBreakdown,
      topCoupons,
    };
  }
}
</file>

